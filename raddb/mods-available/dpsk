#######################################################################
#
#  = DPSK authentication Module
#
#  Calculate dynamic PSKs.
#
#  This module verifies DPSK / EasyPSK style requests by:
#
#	* normalizing request attributes into generic inputs
#	* resolving PSK / PMK material from configured sources
#	* verifying the EAPOL-Key MIC
#	* emitting configured reply attributes
#
#  The underlying PSK / PMK calculation is generic, but different NAS
#  implementations send the request and expect the reply in different
#  vendor-specific attributes.  This module therefore separates:
#
#	* adapter policies - where request and reply attributes live
#	* source policies  - where file-backed PSKs are found
#
#  The "standard" adapter uses generic FreeRADIUS attributes and serves as a
#  reference example.  The additional adapters below show vendor-specific
#  request / reply layouts used in practice.
#
#  Note that you MUST run the "rewrite_called_station_id" policy before calling
#  this module.
#
#  That policy SHOULD create Called-Station-SSID.  If you use the optional
#  "standard" adapter example below, it may also create Called-Station-MAC.
#
#  Then place the following configuration into the "recv Access-Request"
#  section:
#
#	recv Access-Request {
#		...
#		rewrite_called_station_id
#		dpsk
#	}
#
#  And create an "authenticate dpsk" section which calls the "dpsk" module:
#
#	authenticate dpsk {
#		dpsk
#	}
#
#  In the "authenticate" section, the module will return
#
#  * noop	if there are no DPSK attributes in the request
#
#  * fail	if there are DPSK attributes, but it is unable to get the
#		information necessary to check the DPSK data.
#
#  * reject 	if there are DPSK attributes, but they do not match any
#		given PSK.
#
#  * ok		if there are DPSK attributes, and they match a known PSK.
#
#  * updated	if there are DPSK attributes which match a PSK, and the
#		PSK was read from a file-backed source.
#
#  We STRONGLY RECOMMEND THAT NO ONE USE THIS MODULE FOR LARGE DPSK DATA SETS.
#
#  DPSK matching fundamentally relies on brute-force PSK testing.  The server
#  can cache successful results and it can use pre-resolved PSKs or PMKs from a
#  database, but the worst-case file-backed path still scales poorly.
#
#  == Configuration Settings
#
dpsk {
	#
	#  cache_size::
	#
	#  The maximum number of successful DPSK lookups to cache.
	#
	#  The cache is keyed by:
	#
	#	(supplicant MAC + SSID + filename)
	#
	#  Caching can help substantially, even when using a database, because
	#  calculating the PMK from the PSK is relatively expensive.
	#
	cache_size = 1024

	#
	#  cache_lifetime::
	#
	#  How long cache entries are valid for.
	#
	cache_lifetime = 24h

	#
	#  source <name> { ... }
	#
	#  A source policy describes where file-backed PSKs are obtained.
	#
	#  Sources are consulted in the following order:
	#
	#	1. adapter-specific source_names
	#	2. default_source
	#	3. all configured sources in declaration order
	#
	#  The source names are taken from the subsection names.
	#

	#  source csv_fallback::
	#
	#  This source reads PSKs from a CSV file.  It is best used as a fallback
	#  for a small number of entries.
	#
	#  The default CSV format is:
	#
	#	identity,psk,mac,vlan
	#
	#  The mac field is optional.  If present, the entry is treated as
	#  client-bound.  If absent, the entry is used as a fallback candidate.
	#
	#  The vlan field is optional and, if present, can be returned through the
	#  configured VLAN reply policy.
	#
	#  Any process which writes a new CSV file MUST NOT write to the file
	#  directly.  Instead, generate a new file and atomically move it into
	#  place:
	#
	#	create csv file > psk.csv.new
	#	mv psk.csv.new psk.csv
	#
	source csv_fallback {
		type = csv

		csv {
			filename = "${modconfdir}/dpsk/psk.csv"
			format = "identity,psk,mac,vlan"
		}
	}

	#
	#  adapter <name> { ... }
	#
	#  An adapter policy describes how to:
	#
	#	* detect a DPSK request
	#	* map request attributes into generic DPSK inputs
	#	* format the reply attributes on success
	#
	#  Adapters are tried in priority order.  The first adapter which detects
	#  a compatible request is used.
	#
	#  The "standard" adapter below is a generic reference example.  The
	#  additional adapters demonstrate the vendor-specific request / reply
	#  layouts used by current deployments.
	#

	#
	#  adapter standard::
	#
	#  A generic FreeRADIUS attribute path.  Treat this as a reference example
	#  for custom integrations rather than the primary shipped deployment path.
	#
	adapter standard {
		priority = 100
		type = standard_attrs

		request {
			standard {
				#
				#  username::
				#
				#  Attribute containing the supplicant MAC in hex format, e.g.
				#  "abcdef012345".
				#
				username = User-Name

				#
				#  ssid::
				#
				#  Attribute containing the SSID of the network the client is
				#  connecting to.
				#
				ssid = Called-Station-SSID

				#
				#  called_station::
				#
				#  Attribute containing the AP MAC in binary.  This attribute is
				#  usually created by a local rewrite policy.
				#
				called_station = Called-Station-MAC

				#
				#  anonce::
				#
				#  Attribute containing the ANonce from the AP.
				#
				anonce = FreeRADIUS-EV5.802_1X-Anonce

				#
				#  key_msg::
				#
				#  Attribute containing the EAPOL-Key message from the AP.
				#
				key_msg = FreeRADIUS-EV5.802_1X-EAPoL-Key-Msg

				#
				#  master_key / psk / psk_identity::
				#
				#  Optional attributes which can supply PMK / PSK information
				#  directly from another module before file-backed lookup is used.
				#
				#  These attributes are the preferred production path when a
				#  database or another module can resolve PSK / PMK material
				#  directly.
				#
				master_key = control.Pairwise-Master-Key
				psk = control.Pre-Shared-Key
				psk_identity = control.PSK-Identity
			}
		}

		reply {
			mode = standard

			standard {
				psk_attr = reply.Pre-Shared-Key
				psk_identity_attr = reply.PSK-Identity
			}

			vlan {
				mode = tunnel
				tunnel_type_attr = reply.Tunnel-Type
				tunnel_medium_type_attr = reply.Tunnel-Medium-Type
				tunnel_private_group_id_attr = reply.Tunnel-Private-Group-Id
				tunnel_type_value = 13
				tunnel_medium_type_value = 6
			}
		}
	}

	#
	#  adapter ruckus::
	#
	#  Ruckus DPSK parameters are exposed by the dictionary as child TLVs under
	#  `Vendor-Specific.Ruckus.DPSK-Params`, so the shipped adapter reads those
	#  child attributes directly.
	#
	adapter ruckus {
		priority = 10
		type = named_vsa_attrs

		request {
			named_vsa {
				username = User-Name
				ssid = Vendor-Specific.Ruckus.SSID
				called_station = Vendor-Specific.Ruckus.BSSID
				anonce = Vendor-Specific.Ruckus.DPSK-Params.DPSK-Anonce
				key_msg = Vendor-Specific.Ruckus.DPSK-Params.DPSK-EAPOL-Key-Frame
			}
		}

		reply {
			mode = ms_mppe_recv_key

			ms_mppe_recv_key {
				psk_attr = reply.Vendor-Specific.Microsoft.MPPE-Recv-Key
			}

			vlan {
				mode = tunnel
				tunnel_type_attr = reply.Tunnel-Type
				tunnel_medium_type_attr = reply.Tunnel-Medium-Type
				tunnel_private_group_id_attr = reply.Tunnel-Private-Group-Id
				tunnel_type_value = 13
				tunnel_medium_type_value = 6
			}
		}
	}

	#
	#  adapter key_value_vsa::
	#
	#  Example of a request where the inputs are carried as key=value strings in
	#  a repeated VSA.
	#
	adapter iosxe {
		priority = 20
		type = key_value_vsa

		request {
			key_value {
				container_attr = Vendor-Specific.Cisco.AVPair
				username = User-Name
				ssid_key = cisco-wlan-ssid
				called_station_key = cisco-bssid
				anonce_key = cisco-anonce
				key_msg_key = cisco-8021x-data
				value_encoding = radius_escaped
			}
		}

		reply {
			mode = avpair_hex_pmk

			avpair_hex_pmk {
				avpair_attr = reply.Vendor-Specific.Cisco.AVPair
				pmk_key = psk
				extra_pairs = "psk-mode=hex"
			}

			vlan {
				mode = tunnel
				tunnel_type_attr = reply.Tunnel-Type
				tunnel_medium_type_attr = reply.Tunnel-Medium-Type
				tunnel_private_group_id_attr = reply.Tunnel-Private-Group-Id
				tunnel_type_value = 13
				tunnel_medium_type_value = 6
			}
		}
	}

	#
	#  adapter named_vsa_attrs::
	#
	#  Example of a request where each input is carried in a separate named VSA.
	#
	adapter meraki {
		priority = 30
		type = named_vsa_attrs

		request {
			named_vsa {
				username = User-Name
				ssid = Vendor-Specific.Meraki.Meraki-IPSK.Meraki-IPSK-SSID
				called_station = Vendor-Specific.Meraki.Meraki-IPSK.Meraki-IPSK-BSSID
				anonce = Vendor-Specific.Meraki.Meraki-IPSK.Meraki-IPSK-Anonce
				key_msg = Vendor-Specific.Meraki.Meraki-IPSK.Meraki-IPSK-EAPOL
			}
		}

		reply {
			mode = tunnel_password

			tunnel_password {
				psk_attr = reply.Tunnel-Password
			}

			vlan {
				mode = tunnel
				tunnel_type_attr = reply.Tunnel-Type
				tunnel_medium_type_attr = reply.Tunnel-Medium-Type
				tunnel_private_group_id_attr = reply.Tunnel-Private-Group-Id
				tunnel_type_value = 13
				tunnel_medium_type_value = 6
			}
		}
	}
}
