ldap {
	server = 'openldap'
	identity = 'cn=admin,dc=example,dc=com'
	password = 'adminpassword'
	base_dn = 'dc=example,dc=com'

	update {
		control.Password.With-Header	+= 'userPassword'
	}

	user {
		base_dn = "${..base_dn}"
		filter = "(uid=%{Stripped-User-Name || User-Name})"
	}

	options {
		res_timeout = 10
		srv_timelimit = 3
		net_timeout = 10
	}

	pool {
		start = 0
		min = 1
		max = 5
		connecting = 2
		uses = 0
		lifetime = 0
	}
}
