#
#  $FILE{path} reads the entire file at config parse time and
#  substitutes its raw contents into the input stream.  The data
#  file used here has no trailing newline.
#
update request {
	reply:Filter-Id := 'filter'
	Tmp-String-0 := "$FILE{file-data.md}"
}

if (&Tmp-String-0 != "hello\nvalue") {
	update reply {
		Filter-Id += 'fail'
	}
}
