BEGIN PROTOCOL Test-Types 100
ATTRIBUTE	my-string 1 string
ATTRIBUTE	my-octets 2 octets
ATTRIBUTE	my-ipaddr 3 ipaddr
ATTRIBUTE	my-uint8 4 uint8
ATTRIBUTE	my-uint16 5 uint16
ATTRIBUTE	my-uint32 6 uint32
ATTRIBUTE	my-uint64 7 uint64
ATTRIBUTE	my-int32 8 int32
ATTRIBUTE	my-ipv6addr 9 ipv6addr
ATTRIBUTE	my-ipv6prefix 10 ipv6prefix
ATTRIBUTE	my-bool 11 bool
ATTRIBUTE	my-float32 12 float32
ATTRIBUTE	my-float64 13 float64
ATTRIBUTE	my-date 14 date
ATTRIBUTE	my-time-delta 15 time_delta
ATTRIBUTE	my-ether 16 ether
ATTRIBUTE	my-ifid 17 ifid
ATTRIBUTE	my-combo-ipaddr 18 combo-ip
ATTRIBUTE	my-combo-prefix 19 combo-prefix
ATTRIBUTE	my-tlv 20 tlv
ATTRIBUTE	my-int8 21 int8
ATTRIBUTE	my-int16 22 int16
ATTRIBUTE	my-int64 23 int64
END PROTOCOL Test-Types
