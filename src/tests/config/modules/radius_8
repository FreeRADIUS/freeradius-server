#
#  Test: replicate mode with all packet types
#
radius {
	mode = replicate
	transport = udp

	type = Access-Request
	type = Accounting-Request

	require_message_authenticator = no
	response_window = 15
	zombie_period = 10
	revive_interval = 3600

	udp {
		ipaddr = 127.0.0.1
		port = 1812
		secret = testing123
	}

	pool {
		start = 0
		min = 1
		max = 8
		connecting = 1
		uses = 0

		lifetime = 0
		open_delay = 0.2
		close_delay = 1.0
		manage_interval = 0.2

		connection {
			connection_timeout = 3.0
			reconnect_delay = 5
		}

		request {
			per_connection_max = 255
			per_connection_target = 255
			free_delay = 10
		}
	}

	Access-Request {
		initial_rtx_time = 2
		max_rtx_time = 16
		max_rtx_count = 5
		max_rtx_duration = 30
	}

	Accounting-Request {
		initial_rtx_time = 2
		max_rtx_time = 5
		max_rtx_count = 1
		max_rtx_duration = 30
	}
}
