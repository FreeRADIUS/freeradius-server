#!/bin/sh
#
# Minimal configure for rlm_dotnet (no autoconf).
# Probes nethost / hostfxr development layout from a .NET SDK install.
#
AC_MSG() { echo "$*"; }

modname=rlm_dotnet
fail=
targetname=rlm_dotnet
mod_cflags=
mod_ldflags=
with_rlm_dotnet=yes
dotnet_include=

for arg
do
	case "$arg" in
	--without-rlm_dotnet|--with-rlm_dotnet=no)
		with_rlm_dotnet=no
		;;
	--with-dotnet-include-dir=*)
		dotnet_include=`echo "$arg" | sed 's/^--with-dotnet-include-dir=//'`
		;;
	esac
done

if test "$with_rlm_dotnet" = "no"; then
	targetname=
	AC_MSG "*** $modname is disabled."
else
	nethost_native=
	if test -n "$dotnet_include" && test -f "$dotnet_include/nethost.h"; then
		nethost_native=$dotnet_include
	fi
	if test -z "$nethost_native"; then
		for base in "$DOTNET_ROOT" /usr/share/dotnet /usr/lib/dotnet /usr/local/share/dotnet; do
			test -z "$base" && continue
			test -d "$base" || continue
			for native in "$base"/packs/Microsoft.NETCore.App.Host.*/*/runtimes/*/native; do
				if test -f "$native/nethost.h"; then
					nethost_native=$native
					break 2
				fi
			done
		done
	fi
	if test -z "$nethost_native" || test ! -f "$nethost_native/nethost.h"; then
		fail="${fail} nethost.h"
	fi
	if test -n "$nethost_native"; then
		mod_cflags="-I$nethost_native"
		case "$nethost_native" in
		*aix*) ;;
		*osx*|*darwin*)
			if test -f "$nethost_native/libnethost.dylib"; then
				mod_ldflags="-L$nethost_native -lnethost -Wl,-rpath,$nethost_native"
			else
				fail="${fail} libnethost.dylib"
			fi
			;;
		*)
			if test -f "$nethost_native/libnethost.so"; then
				mod_ldflags="-L$nethost_native -lnethost -Wl,-rpath,$nethost_native"
			else
				fail="${fail} libnethost.so"
			fi
			;;
		esac
	fi
	mod_ldflags="$mod_ldflags -ldl -lpthread"

	if test -n "$fail"; then
		if test "x$enable_strict_dependencies" = "xyes"; then
			AC_MSG "ERROR: $modname missing:$fail"
			AC_MSG "Install a .NET SDK or pass --with-dotnet-include-dir=/path/to/nethost/native"
			exit 1
		fi
		AC_MSG "WARNING: $modname not built (missing:$fail)."
		AC_MSG "WARNING: Use --without-rlm_dotnet to silence, or install .NET SDK headers/libs."
		targetname=
	fi
fi

cat > config.h <<'HDR'
/* Generated by rlm_dotnet/configure */
#ifndef RLM_DOTNET_CONFIG_H
#define RLM_DOTNET_CONFIG_H
#endif
HDR

if test -n "$targetname"; then
	AC_MSG "$modname: yes (nethost found)"
else
	AC_MSG "$modname: no"
fi

sed -e "s%@targetname@%$targetname%g" \
    -e "s%@mod_cflags@%$mod_cflags%g" \
    -e "s%@mod_ldflags@%$mod_ldflags%g" \
    < all.mk.in > all.mk

exit 0
